# Supabase (same project as website — shared accounts and data)
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Avently web API base URL (for /api/auth/me and other API calls)
# e.g. https://www.avently.co.uk or http://localhost:3000
EXPO_PUBLIC_APP_URL=https://www.avently.co.uk
